<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.shenyuanlaolarou.opencodewebui</id>
    <name>opencode-web-ui</name>
    <vendor email="shenyuanlaolarou@users.noreply.github.com" url="https://github.com/syllr/intellij-opencode-web">shenyuanlaolarou</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <actions>
        <!-- 覆盖 Cmd+, (设置快捷键)，在 JCEF 有焦点时传递给 JCEF -->
        <action id="com.shenyuanlaolarou.opencodewebui.PassToJcefSettings" 
                class="com.github.xausky.opencodewebui.actions.PassToJcefAction" 
                text="Pass Settings to JCEF">
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta COMMA" replace-all="true"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl COMMA" replace-all="true"/>
        </action>
        
        <!-- 覆盖 Cmd+K，在 JCEF 有焦点时传递给 JCEF -->
        <action id="com.shenyuanlaolarou.opencodewebui.PassToJcefCmdK" 
                class="com.github.xausky.opencodewebui.actions.PassToJcefAction" 
                text="Pass Cmd+K to JCEF">
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta K" replace-all="true"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl K" replace-all="true"/>
        </action>
        
        <!-- Copy as Prompt - 在编辑器右键菜单添加选项 -->
        <action id="com.shenyuanlaolarou.opencodewebui.CopyAsPrompt"
                class="com.github.xausky.opencodewebui.actions.CopyAsPromptAction"
                text="Copy as Prompt"
                description="Copy selected text as prompt to clipboard">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="$Paste"/>
            <add-to-group group-id="CutCopyPasteGroup" anchor="after" relative-to-action="$Copy"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.xausky.opencodewebui.toolWindow.MyToolWindowFactory" id="OpenCodeWeb" anchor="right" icon="/icons/ocw.svg" displayName="OpenCodeWeb"/>
        <postStartupActivity implementation="com.github.xausky.opencodewebui.startup.MyStartupActivity"/>
    </extensions>
</idea-plugin>
